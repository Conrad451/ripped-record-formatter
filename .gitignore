# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# PyInstaller build output
# build/ and dist/ are regenerated on every build, so they stay ignored.
# *.spec is intentionally NOT ignored: a spec file can carry hand-tuned build
# configuration worth versioning. None exists yet; if one is added deliberately
# it should be committed.
build/
dist/

# Packaging / distribution
*.egg-info/
.eggs/

# Test / coverage artifacts
.pytest_cache/
.coverage
htmlcov/

# Environment / secrets
.env

# Claude Code local session files
.claude/

# IDE / editor
.idea/
.vscode/

# OS cruft
Thumbs.db
desktop.ini
.DS_Store

# Vendored binaries fetched by scripts/fetch_ffmpeg.py (large, separately licensed).
vendor/

# Generated by the PyInstaller spec at build time.
SOURCE.txt

# Release artifacts built by PyInstaller; attached to the GitHub release, never committed.
*.zip
# ...and the zip extracted in place, which is what verifying a release looks
# like. Byte-reproducible from the zip beside it, so it is output, not source.
RippedRecordFormatter-*-win64/
